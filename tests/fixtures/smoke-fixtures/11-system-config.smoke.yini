/*
  Highlights:
  - Section header usage (`^ System`)
  - Inline object assignment (`config = { ... }`)
  - Nested inline objects (`services`, `web`, `database`)
  - Arrays of scalars (`ports`)
  - Arrays of inline objects (`routes`, `replicas`)
  - Mixed value types: strings, numbers, booleans, null, objects, arrays
  - Small edge cases: empty array, empty object, float, boolean aliases
  - Real-world style config modeling (web routes + DB replica roles)
*/

^ System

config = {
  name: "production",
  enabled: on,
  version: 1.5,
  metadata: {},
  tags: [],
  fallback_host: null,
  services: {
    web: {
      ports: [80, 443],
      routes: [
        { path: "/", secure: true },
        { path: "/api", secure: false }
      ]
    },
    database: {
      replicas: [
        { host: "db1", role: "primary" },
        { host: "db2", role: "secondary" }
      ],
      readonly: off
    }
  }
}

/END
