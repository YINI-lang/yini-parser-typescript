/*

Features:
  - No (explicit) section
  - Lists (bracketed and colon)
  - Strings, booleans, numbers
  - File paths (with \)
  - Everything in PascalCase
  - Comments

*/

// App Preferences

ShowTips = False
RecentFiles = [
  "\home\user\docs\report.docx",
  "\home\user\docs\notes.txt",
]
FileFilters = ["*.docx", "*.txt", "*.md"]
CacheFolder = Null
CacheFolder2 =    // NOTE: Empty values are allowed in lenient mode and disallowed in strict mode.

; Backup Preferences
Backup = True
BackupInterval = 10                       # In minutes.
BackupPath = "\home\user\backups\"
